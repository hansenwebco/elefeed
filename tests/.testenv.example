# Test Environment Configuration
# This file is git-ignored and never committed to the repository.
# Use it to store test credentials or test instance details.

# Optional: Mastodon test server details (for live server testing)
# TEST_SERVER=test.example.com
# TEST_TOKEN=your-test-token-here
# TEST_USERNAME=testuser

# Demo mode (show mock data without login)
# DEMO_MODE=true
